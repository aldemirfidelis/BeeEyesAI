# Desabilita listagem de diretório
Options -Indexes

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Não reescrever requisições para a API PHP
  # Se já existir outra pasta api/, usamos também beeeyes_api/
  RewriteCond %{REQUEST_URI} ^/(api|beeeyes_api)/ [NC]
  RewriteRule ^ - [L]

  # Arquivos existentes passam direto
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Redireciona tudo para index.html (SPA)
  RewriteRule ^ index.html [L]
</IfModule>

AddType text/javascript .js
AddType text/css .css
