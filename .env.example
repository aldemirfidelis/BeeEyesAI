# Database (PostgreSQL - use Neon free tier: https://neon.tech)
DATABASE_URL=postgres://user:password@host/dbname

# Groq API key (https://console.groq.com) — provider primário (grátis)
GROQ_API_KEY=gsk_...

# Google Gemini API key (https://aistudio.google.com/apikey) — fallback automático quando Groq atinge o limite
GEMINI_API_KEY=AIza...

# JWT Secret (generate a random 32+ char string)
JWT_SECRET=change-this-to-a-secure-random-string

# Mobile app API URL (set this in mobile/.env or EAS secrets)
# For Android emulator use: http://10.0.2.2:5000
# For iOS simulator use: http://localhost:5000
# For production: https://your-api-domain.com
EXPO_PUBLIC_API_URL=http://10.0.2.2:5000
